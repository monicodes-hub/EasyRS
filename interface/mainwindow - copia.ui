  <property name="styleSheet">
   <string notr="true">/* Main window background */

QMainWindow, #centralwidget {

/* border-image hace que la imagen se adapte al tamaño de la ventana sin repetirse */

	border-image: url(:/background/resources/background_2.0.png) 0 0 0 0 stretch stretch;

}



/* GroupBox: slightly darker, rounded corners, SEGOE UI, 14pt, white text */

QGroupBox {

    /* Un borde cyan semitransparente da un efecto cristal muy moderno */
    border: 2px solid rgba(34, 9, 67, 0.4); 
    border-radius: 20px; 
    margin-top: 15px;    
    padding: 16px; 
    font-family: 'Segoe UI', Segoe, Arial, sans-serif;
    font-size: 14pt;
}



/* GroupBox title: white, bold, with background and padding */

QGroupBox::title {

subcontrol-origin: margin;

subcontrol-position: top left;

left: 20px;

padding: 0 5px 0 5px;

color: #7bc1d4;

font-weight: bold;

font-family: 'Segoe UI', Segoe, Arial, sans-serif;

font-size: 14pt;

border-radius: 10px;

}



/* Frames: transparent to let main bg show through */

QFrame {

background: transparent;

border: none;

}



/* Buttons: only for button1_routing and button2_conversations, white text */

QPushButton#button1_routing, QPushButton#button2_conversations {

font-family: 'Segoe UI', Segoe, Arial, sans-serif;

font-size: 14pt;

color: #fff;

background-color: #7c6fc2;

border-radius: 10px;

padding: 8px 16px;



border: 2px solid transparent;

transition: border 0.2s, box-shadow 0.2s;

}

QPushButton#button1_routing:hover, QPushButton#button2_conversations:hover {
	background-color: #7c6fc2;
    /* Efecto Neón: Cambiamos el color del borde para simular un resplandor cyan */
    border: 2px solid #7bc1d4; 
}
	/*background-color: #625090;
	border: 2px solid #614f90;
	box-shadow: 0 0 0 2px #7bc1d4;
}*/


QPushButton#button1_routing:pressed, QPushButton#button2_conversations:pressed {
    background-color: #220943;
    border: 2px solid #625090;
	padding: 9px 17px 7px 19px;
}

	/*background-color: #6a5fb2;
}*/


/* Other buttons: subtle style, rounded, white text */

QPushButton {

background-color: #220943;

color: #7bc1d4;

border-radius: 10px;

padding: 6px 18px;

font-size: 15px;



border: 2px solid transparent;

transition: border 0.2s, box-shadow 0.2s;

}

QPushButton:hover {
    background-color: #625090;
    color: #ffffff; /* Al pasar el ratón, el texto pasa a blanco para contrastar */
    border: 1px solid #7bc1d4; /* El borde se ilumina */
}

/*background-color: #625090;

border: 2px solid #fff;

box-shadow: 0 0 0 2px #7bc1d4;

}*/

QPushButton:pressed {
    background-color: #2F1651;
    color: #ffffff; /* Al pasar el ratón, el texto pasa a blanco para contrastar */
    border: 1px solid #7bc1d4; /* El borde se ilumina */
	padding: 9px 17px 7px 19px;
}

/*background-color: #6a5fb2;

}*/



/* Labels: white text for headers/footers */

QLabel#logo_header, QLabel#logo_footer {

color: #fff;

font-size: 18px;

font-weight: bold;

}



/* Status bar: match main color, white text */

QStatusBar {

background: #2A0E4F;

color: #7bc1d4;

border-top: 1px solid #220943;

}</string>
